# Copia para src-tauri/.env.
# Os botões "Claude"/"GPT" da app usam, por esta ordem:
#   1) ANTHROPIC_API_KEY (sk-ant-…)  → Claude nativo
#   2) OPENROUTER_API_KEY (sk-or-…)  → Claude/GPT via OpenRouter
#   3) sem key                        → Ollama local (grátis)

# Para usar Ollama local (grátis): NÃO metas nenhuma key, só o modelo.
JARVIS_MODEL=llama3.1:8b

# Cloud (opcional) — descomenta uma:
# OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_API_KEY=sk-ant-...

# URL do cérebro Jarvis (servidor multi-agente).
JARVIS_SERVER_URL=http://localhost:8791

# Igual ao do servidor, se este tiver auth ligada.
JARVIS_API_TOKEN=
