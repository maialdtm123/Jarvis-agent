# === Escolhe UM modo ===

# MODO A — Ollama local (grátis, privado, offline). RECOMENDADO.
JARVIS_PROVIDER=ollama
JARVIS_MODEL=llama3.1:8b
# OLLAMA_URL=http://localhost:11434/v1/chat/completions   (default)
# OLLAMA_EMBEDDINGS_URL=http://localhost:11434/api/embeddings   (default)
JARVIS_EMBEDDING_MODEL=nomic-embed-text
# JARVIS_VECTOR_DB=./data/memory.db   (default)

# MODO B — OpenRouter (modelos grátis ou, com saldo, Claude/GPT)
# OPENROUTER_API_KEY=sk-or-v1-...
# JARVIS_MODEL=meta-llama/llama-3.3-70b-instruct:free

# MODO C — Anthropic nativo (precisa de créditos de API)
# ANTHROPIC_API_KEY=sk-ant-...
# JARVIS_MODEL=claude-opus-4-8

# Comum
PORT=8791
# Segurança: se definires um token, /chat e /reset exigem header x-jarvis-token.
JARVIS_API_TOKEN=

# MODO D — Tavily + filesystem allowlist
# TAVILY_API_KEY=tvly-...
# JARVIS_ALLOWED_DIRS=C:\Users\LauroM\Documents\jarvis-ui

# MODO E — shell tool no WSL2 (gate D4)
# Só nomes simples de executável; não adicionar shells nem interpretadores.
# JARVIS_ALLOWED_COMMANDS=pwd,ls,git,npm,cargo
# JARVIS_SHELL_TIMEOUT_MS=15000
